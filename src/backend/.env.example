# Copy this file to .env and adjust values for your machine.
# The .env file is intentionally ignored by git.

# Docker Compose project name. Change this if you run multiple Cocanvas copies.
COMPOSE_PROJECT_NAME=cocanvas

# Host ports. Container ports stay fixed.
# 注意：后端 8080 端口不对宿主机暴露（docker-compose.yml 无 ports 映射），
# 统一由 Nginx 80 端口接入，所以这里无 BACKEND_HOST_PORT。
REDIS_HOST_PORT=6379
MYSQL_HOST_PORT=3307

# Local MySQL bootstrap values.
MYSQL_ROOT_PASSWORD=cocanvas123
MYSQL_DATABASE=cocanvas

# Proxy used only while Docker build runs Gradle inside a build container.
# For local HTTP/SOCKS HTTP proxy on the host, the default usually works
# together with build.network=host in docker-compose.yml.
# 注意这里windows要改成host.docker.internal
GRADLE_PROXY_HOST=127.0.0.1
GRADLE_PROXY_PORT=7890
